{
  "name": "image-api",
  "version": "0.1.0",
  "private": true,
  "description": "Small image upload REST API.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.js",
    "prebuild": "npm run check:node",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "npm run check:node",
    "start": "node dist/main",
    "prestart:dev": "npm run check:node",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "prestart:prod": "npm run check:node",
    "start:prod": "node dist/main",
    "prelint": "npm run check:node",
    "lint": "eslint \"src/**/*.ts\"",
    "pretest": "npm run check:node",
    "test": "jest",
    "pretest:watch": "npm run check:node",
    "test:watch": "jest --watch",
    "pretest:cov": "npm run check:node",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
